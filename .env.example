# Skill Orchestrator SDK Environment Configuration

# ============================================================
# LLM Configuration (Required)
# Used for: Capability tree construction and skill search
# ============================================================
LLM_MODEL=openai/anthropic/claude-opus-4.5
LLM_BASE_URL=https://openrouter.ai/api/v1
LLM_API_KEY=your-openrouter-api-key-here

# ============================================================
# OpenRouter API Key (Optional)
# Used for: generate-image skill (calls image generation models)
# Required only if you use the generate-image skill
# ============================================================
OPENROUTER_API_KEY=your-openrouter-api-key-here

# ============================================================
# Embedding Configuration (Optional)
# Used for: Offline analysis tools only (tools/analysis/)
# NOT used in the main skill retrieval pipeline
# ============================================================
EMBEDDING_MODEL=openai/text-embedding-3-large
EMBEDDING_BASE_URL=https://api.openai.com/v1
EMBEDDING_API_KEY=your-openai-api-key-here

# ============================================================
# Fallback Configuration (Optional)
# If LLM/EMBEDDING specific variables are not set, these are used
# ============================================================
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_API_KEY=your-api-key-here

# ============================================================
# Proxy Configuration (Optional)
# ============================================================
# https_proxy=http://127.0.0.1:7890
# http_proxy=http://127.0.0.1:7890
# all_proxy=socks5://127.0.0.1:7890
